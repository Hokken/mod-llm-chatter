#
# LLM Chatter Module Configuration
#
# Dynamic bot conversations powered by AI
# Replaces static database messages with contextual, personality-driven chatter
#
# SUPPORTED PROVIDERS:
#   - anthropic : Claude models (Haiku, Sonnet, Opus) - cloud, requires API key
#   - openai    : GPT models (GPT-4o, GPT-4o-mini) - cloud, requires API key
#   - ollama    : Local models (Qwen3, Llama, Mistral, etc.) - runs locally, FREE
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to your server's config directory as mod_llm_chatter.conf
# 2. Choose your provider and configure settings below
# 3. Run the SQL migration to create the tables
# 4. Start the Python bridge: python tools/llm_chatter_bridge.py --config /path/to/mod_llm_chatter.conf
# 5. Set LLMChatter.Enable = 1 and restart the worldserver
#

###############################################################################
# GENERAL SETTINGS
###############################################################################

#
#   LLMChatter.Enable
#       Enable or disable the LLM Chatter module
#       Default: 0 (disabled)
#
LLMChatter.Enable = 1

#
#   LLMChatter.ChatterMode
#       Controls the personality style of bot chat messages
#       "normal"   - Casual MMO chat: abbreviations, game terms, OOC references (default)
#       "roleplay" - Fully in-character: race/class personality, lore-influenced speech, no game terms
#       Default: roleplay
#
LLMChatter.ChatterMode = roleplay

#
#   LLMChatter.EnableVerboseLogging
#       Enable detailed logging for debugging (prompt creativity, mood, timing, etc.)
#       Disable in production to reduce log volume and improve performance
#       NOTE: Not yet connected to conditions - will be implemented before release
#       Default: 1 (enabled for development)
#
LLMChatter.EnableVerboseLogging = 1

#
#   LLMChatter.TriggerIntervalSeconds
#       How often (in seconds) the server considers triggering new chatter
#       Actual chatter may not happen every interval (depends on chance)
#       Default: 60
#
LLMChatter.TriggerIntervalSeconds = 60

#
#   LLMChatter.ConversationChance
#       Chance (0-100) that a trigger results in a conversation vs statement
#       100 = always conversation, 0 = always single statement
#       Default: 50
#
LLMChatter.ConversationChance = 50

#
#   LLMChatter.TriggerChance
#       Chance (0-100) that each interval actually triggers chatter
#       Adds randomness so chatter doesn't feel too regular
#       Default: 15
#
LLMChatter.TriggerChance = 15

#
#   LLMChatter.CityChatterMultiplier
#       Multiplier applied to TriggerChance when a
#       player is in a capital city (Stormwind,
#       Orgrimmar, Darnassus, etc.). Cities had more
#       General chat in retail WoW.
#       Example: TriggerChance=15, Multiplier=2
#       -> 30% chance in cities, 15% outside.
#       Set to 1 to disable city boost.
#       Default: 2
#
LLMChatter.CityChatterMultiplier = 2

#
#   LLMChatter.MaxPendingRequests
#       Maximum pending requests in queue before stopping new triggers
#       Prevents queue buildup if bridge is slow
#       Default: 5
#
LLMChatter.MaxPendingRequests = 5

###############################################################################
# MESSAGE DELIVERY SETTINGS
###############################################################################

#
#   LLMChatter.DeliveryPollMs
#       How often (ms) the server checks for messages to deliver
#       Default: 1000
#
LLMChatter.DeliveryPollMs = 1000

#
#   LLMChatter.MessageDelayMin
#       Minimum delay (ms) between conversation messages
#       Used as lower bound for dynamic delay calculation
#       Default: 1000
#
LLMChatter.MessageDelayMin = 1000

#
#   LLMChatter.MessageDelayMax
#       Maximum delay (ms) between conversation messages
#       Used as upper bound for dynamic delay calculation
#       Default: 30000
#
LLMChatter.MessageDelayMax = 30000

###############################################################################
# LLM PROVIDER SETTINGS
###############################################################################
#
# To switch providers, just change LLMChatter.Provider and LLMChatter.Model.
# Only configure the settings for your chosen provider.
#
# QUICK SETUP EXAMPLES:
#
#   Cloud (Anthropic Claude Haiku - recommended for quality):
#     LLMChatter.Provider = anthropic
#     LLMChatter.Model = claude-haiku-4-5-20251001
#     LLMChatter.Anthropic.ApiKey = sk-ant-xxxxx
#
#   Cloud (OpenAI GPT-4o-mini - fast and cheap):
#     LLMChatter.Provider = openai
#     LLMChatter.Model = gpt-4o-mini
#     LLMChatter.OpenAI.ApiKey = sk-xxxxx
#
#   Local (Ollama with Qwen3 - FREE, runs on your machine):
#     LLMChatter.Provider = ollama
#     LLMChatter.Model = qwen3:4b
#     (install Ollama, run: ollama pull qwen3:4b)
#
###############################################################################

#
#   LLMChatter.Provider
#       Which LLM provider to use: "anthropic", "openai", or "ollama"
#       Default: anthropic
#
LLMChatter.Provider = anthropic

#
#   LLMChatter.Model
#       Full model name to use with your provider.
#
#       Anthropic models:
#         claude-haiku-4-5-20251001 (fast, cheap)
#         claude-sonnet-4-5-20250929 (balanced)
#         claude-opus-4-6 (highest quality)
#
#       OpenAI models:
#         gpt-4o-mini (fast, cheap)
#         gpt-4o (balanced)
#
#       Ollama models (from 'ollama list'):
#         qwen3:4b, qwen3:8b, llama3.2:3b, etc.
#
#       Default: claude-haiku-4-5-20251001
#
LLMChatter.Model = claude-haiku-4-5-20251001

###############################################################################
# ANTHROPIC SETTINGS (only needed if Provider = anthropic)
###############################################################################

#
#   LLMChatter.Anthropic.ApiKey
#       Your Anthropic API key (starts with sk-ant-)
#       Get one at: https://console.anthropic.com/
#
LLMChatter.Anthropic.ApiKey =

###############################################################################
# OPENAI SETTINGS (only needed if Provider = openai)
###############################################################################

#
#   LLMChatter.OpenAI.ApiKey
#       Your OpenAI API key (starts with sk-)
#       Get one at: https://platform.openai.com/api-keys
#
LLMChatter.OpenAI.ApiKey =

###############################################################################
# OLLAMA SETTINGS (only needed if Provider = ollama)
###############################################################################
#
# Ollama runs models locally on your machine - no API key needed!
# Install: https://ollama.ai
# Pull a model: ollama pull qwen3:4b
#

#
#   LLMChatter.Ollama.BaseUrl
#       Ollama API endpoint. Default works for standard local installation.
#       Change if running Ollama on another machine or port.
#       Default: http://localhost:11434
#
LLMChatter.Ollama.BaseUrl = http://localhost:11434

#
#   LLMChatter.Ollama.ContextSize
#       Context window size (num_ctx). Smaller = faster, less memory.
#       1024 is good for short chatter messages.
#       Increase if you get truncated responses.
#       Default: 2048
#
LLMChatter.Ollama.ContextSize = 2048

#
#   LLMChatter.Ollama.DisableThinking
#       Some models like Qwen3 have "thinking" mode enabled by default,
#       which adds internal reasoning before responding. This makes responses
#       slower and uses more resources - overkill for simple chatter.
#       Set to 1 to add /no_think to prompts (recommended for Qwen3).
#       Default: 1
#
LLMChatter.Ollama.DisableThinking = 1

###############################################################################
# COMMON LLM SETTINGS (apply to all providers)
###############################################################################

#
#   LLMChatter.MaxTokens
#       Maximum tokens in the LLM response
#       NOTE: 350 is baseline; conversations can override with ConversationMaxTokens
#       Default: 350
#
LLMChatter.MaxTokens = 350

#
#   LLMChatter.ConversationMaxTokens
#       Maximum tokens for conversation responses (2-4 messages)
#       Recommended: 700-800 to avoid JSON truncation
#       Default: 700
#
LLMChatter.ConversationMaxTokens = 700

#
#   LLMChatter.Temperature
#       LLM temperature (0.0 = focused, 1.0 = creative)
#       Higher = more varied/creative chatter
#       Default: 0.8
#
LLMChatter.Temperature = 0.8

#
#   LLMChatter.LootRecentCooldownSeconds
#       Prevents ambient zone chatter from mentioning the same
#       loot item repeatedly. If bots already chatted about an
#       item in a zone, they won't mention it again for this
#       many seconds.
#       Default: 1200 (20 minutes)
#
LLMChatter.LootRecentCooldownSeconds = 1200

#
#   LLMChatter.LongMessageChance
#       Percent chance (0-100) that a bot's message is allowed
#       to be longer than the usual 1-2 sentence limit. When
#       triggered, the LLM prompt relaxes the brevity constraint
#       for a more expressive message.
#       Default: 15
#
LLMChatter.LongMessageChance = 15

###############################################################################
# DATABASE SETTINGS (Used by Python bridge)
###############################################################################

#
#   LLMChatter.Database.Host
#       Database server hostname
#       Default: localhost
#
LLMChatter.Database.Host = localhost

#
#   LLMChatter.Database.Port
#       Database server port
#       Default: 3306
#
LLMChatter.Database.Port = 3306

#
#   LLMChatter.Database.User
#       Database username
#       Default: acore
#
LLMChatter.Database.User = acore

#
#   LLMChatter.Database.Password
#       Database password
#       Default: acore
#
LLMChatter.Database.Password = acore

#
#   LLMChatter.Database.Name
#       Characters database name
#       Default: acore_characters
#
LLMChatter.Database.Name = acore_characters

#
#   LLMChatter.Bridge.PollIntervalSeconds
#       How often the Python bridge checks for new requests
#       Default: 3
#
LLMChatter.Bridge.PollIntervalSeconds = 3

###############################################################################
# EVENT SYSTEM SETTINGS
###############################################################################

#
#   LLMChatter.UseEventSystem
#       Enable the event-driven chatter system
#       Events like holidays and day/night transitions trigger contextual chatter
#       Default: 1 (enabled)
#
LLMChatter.UseEventSystem = 1

#
#   LLMChatter.EnvironmentCheckSeconds
#       How often (in seconds) to check for
#       environment changes (day/night transitions,
#       active holidays in cities, etc.)
#       Default: 60
#
LLMChatter.EnvironmentCheckSeconds = 60

#
#   LLMChatter.EventReactionChance
#       Base chance (0-100) that any event triggers a reaction
#       Most events should NOT trigger chatter for naturalism
#       Default: 15
#
LLMChatter.EventReactionChance = 15

#
#   LLMChatter.EventConversationChance
#       When an event triggers chatter, chance (0-100) it's a multi-bot
#       conversation vs single statement
#       100 = always conversation, 0 = always statement
#       Conversations require at least 2 bots in the zone
#       Default: 60
#
LLMChatter.EventConversationChance = 60

#
#   LLMChatter.TransportEventChance
#       Override chance for transport_arrives events (0 = use EventReactionChance)
#       Default: 0
#
LLMChatter.TransportEventChance = 0

#
#   LLMChatter.TransportCooldownSeconds
#       Cooldown per transport+zone arrival event (seconds)
#       Default: 600 (10 minutes). Set to 0 to announce every arrival.
#
LLMChatter.TransportCooldownSeconds = 600

#
#   LLMChatter.TransportCheckSeconds
#       How often (in seconds) to scan transport
#       positions for zone changes
#       Default: 5
#
LLMChatter.TransportCheckSeconds = 5

#
#   LLMChatter.WeatherCooldownSeconds
#       Cooldown per zone for weather change events
#       Default: 1800 (30 minutes)
#
LLMChatter.WeatherCooldownSeconds = 1800

#
#   LLMChatter.DayNightCooldownSeconds
#       Cooldown for day/night transition events
#       Default: 7200 (2 hours)
#
LLMChatter.DayNightCooldownSeconds = 7200

#
#   LLMChatter.HolidayCooldownSeconds
#       Per-city cooldown for recurring holiday
#       mentions while in a capital city
#       Default: 1800 (30 minutes)
#
LLMChatter.HolidayCooldownSeconds = 1800

#
#   LLMChatter.HolidayCityChance
#       Chance (0-100) per environment check that a
#       holiday mention triggers while in a capital
#       city. At default 60s check interval, 10%
#       means roughly one mention every 10 minutes.
#       Default: 10
#
LLMChatter.HolidayCityChance = 10

#
#   LLMChatter.HolidayZoneChance
#       Chance (0-100) per environment check that a
#       holiday mention triggers in open-world zones
#       (non-city). Lower than city chance since
#       holiday awareness is less prominent outside
#       cities.
#       Default: 5
#
LLMChatter.HolidayZoneChance = 5

#
#   LLMChatter.EventExpirationSeconds
#       How long (seconds) before unprocessed events expire
#       Default: 600 (10 minutes)
#
LLMChatter.EventExpirationSeconds = 600

#
#   LLMChatter.GlobalMessageCap
#       Max messages across ALL zones per GlobalCapWindowSeconds
#       Prevents world-wide spam during high activity
#       Default: 8
#
LLMChatter.GlobalMessageCap = 8

#
#   LLMChatter.GlobalCapWindowSeconds
#       Time window for GlobalMessageCap
#       Default: 300 (5 minutes)
#
LLMChatter.GlobalCapWindowSeconds = 300

#
#   LLMChatter.TransportBypassGlobalCap
#       Allow transport arrival events to bypass GlobalMessageCap.
#       Useful if you want boats/zeppelins to always be announced
#       even when the global message limit has been reached.
#       Default: 0 (disabled - transports respect global cap)
#
LLMChatter.TransportBypassGlobalCap = 0

#
#   LLMChatter.BotSpeakerCooldownSeconds
#       How long before same bot can speak again
#       Spreads voices across different bots
#       Default: 900 (15 minutes)
#
LLMChatter.BotSpeakerCooldownSeconds = 900

#
#   LLMChatter.ZoneFatigueThreshold
#       Max event-triggered messages a single zone can produce
#       within ZoneFatigueCooldownSeconds. Prevents one busy zone
#       from dominating all chatter (e.g. a zone with frequent
#       weather changes or transport arrivals).
#       Default: 3
#
LLMChatter.ZoneFatigueThreshold = 3

#
#   LLMChatter.ZoneFatigueCooldownSeconds
#       Time window for zone fatigue
#       Default: 900 (15 minutes)
#
LLMChatter.ZoneFatigueCooldownSeconds = 900

###############################################################################
# EVENT TYPE TOGGLES
# Only safe, low-frequency events are supported to ensure server stability.
# High-frequency events (creature spawns, deaths, player level ups, etc.)
# have been removed as they can cause crashes with playerbots.
###############################################################################

#
#   LLMChatter.Events.Holidays
#       React to holiday start/stop events (very rare)
#       Default: 1 (enabled)
#
LLMChatter.Events.Holidays = 1

#
#   LLMChatter.Events.DayNight
#       React to time-of-day transitions
#       Tracks: dawn, early_morning, morning, midday, afternoon, evening, dusk, night, midnight, late_night
#       Default: 1 (enabled)
#
LLMChatter.Events.DayNight = 1

#
#   LLMChatter.Events.Weather
#       React to weather changes (rain, snow, fog, sandstorms, etc.)
#       Tracks transitions: starting, clearing, intensifying
#       Default: 1 (enabled)
#
LLMChatter.Events.Weather = 1

#
#   LLMChatter.Events.Transports
#       React to transport arrivals (boats, zeppelins entering zones)
#       Bots may comment when a transport arrives in their zone
#       Default: 1 (enabled)
#
LLMChatter.Events.Transports = 1

#
#   LLMChatter.Events.MinorEvents
#       React to minor game events like Call to Arms
#       BG rotations, fishing derbies, and fireworks.
#       These trigger less often than holidays for
#       occasional immersion flavor.
#       Default: 1 (enabled)
#
LLMChatter.Events.MinorEvents = 1

#
#   LLMChatter.Events.MinorEventChance
#       Chance (0-100) that a minor event triggers
#       a chatter reaction per environment check.
#       Lower than holiday chance since these are
#       less significant events.
#       Default: 20
#
LLMChatter.Events.MinorEventChance = 20

###############################################################################
# GROUP CHATTER SETTINGS
###############################################################################

#
#   LLMChatter.GroupChatter.Enable
#       Enable group chatter when bots are grouped with real players.
#       Bots will react in party chat to events like kills, deaths,
#       loot drops, player messages, and idle downtime. Each event
#       type has its own chance and cooldown settings below.
#       Default: 1 (enabled)
#
LLMChatter.GroupChatter.Enable = 1

#
#   LLMChatter.GroupChatter.IdleChance
#       Percent chance (0-100) that bots in a group start
#       chatting among themselves during downtime (no combat,
#       no events). Checked every IdleCheckInterval seconds.
#       Default: 10
#
LLMChatter.GroupChatter.IdleChance = 10

#
#   LLMChatter.GroupChatter.IdleCheckInterval
#       How often (seconds) the bridge checks whether grouped
#       bots should start idle chatter. Each check rolls against
#       IdleChance to decide if chatter happens.
#       Default: 60
#
LLMChatter.GroupChatter.IdleCheckInterval = 60

#
#   LLMChatter.GroupChatter.IdleCooldown
#       Minimum seconds between idle chatter triggers
#       for the same group. Prevents back-to-back idle
#       conversations even if IdleChance rolls succeed.
#       Default: 30
#
LLMChatter.GroupChatter.IdleCooldown = 30

#
#   LLMChatter.GroupChatter.ConversationBias
#       Percent chance (0-100) that idle chatter is a
#       multi-bot conversation (2+ bots talking back and
#       forth) vs a single bot making a one-off comment.
#       Requires 2+ bots in the group for conversations.
#       Default: 50
#
LLMChatter.GroupChatter.ConversationBias = 50

#
#   LLMChatter.GroupChatter.IdleHistoryLimit
#       Number of recent chat messages to include
#       as context for idle chatter prompts.
#       Lower = less echo chamber, higher = more
#       continuity.
#       Default: 5
#
LLMChatter.GroupChatter.IdleHistoryLimit = 5

#
#   LLMChatter.GroupChatter.KillChanceNormal
#       Percent chance (0-100) that a normal mob kill
#       triggers a group reaction.
#       Boss and rare kills always trigger (100%).
#       Default: 10
#
LLMChatter.GroupChatter.KillChanceNormal = 10

#
#   LLMChatter.GroupChatter.DeathChance
#       Percent chance (0-100) that a bot death
#       triggers a group reaction.
#       Default: 40
#
LLMChatter.GroupChatter.DeathChance = 40

#
#   LLMChatter.GroupChatter.LootChanceGreen
#       Percent chance (0-100) that looting a green
#       quality item triggers a group reaction.
#       Default: 20
#
LLMChatter.GroupChatter.LootChanceGreen = 20

#
#   LLMChatter.GroupChatter.LootChanceBlue
#       Percent chance (0-100) that looting a blue
#       quality item triggers a group reaction.
#       Epic+ loot always triggers (100%).
#       Default: 50
#
LLMChatter.GroupChatter.LootChanceBlue = 50

#
#   LLMChatter.GroupChatter.QuestObjectiveChance
#       Percent chance (0-100) that completing a
#       quest objective triggers a group reaction.
#       Default: 30
#
LLMChatter.GroupChatter.QuestObjectiveChance = 30

#
#   LLMChatter.GroupChatter.QuestObjectiveCooldown
#       Per-group cooldown (seconds) between quest
#       objective reactions.
#       Default: 30
#
LLMChatter.GroupChatter.QuestObjectiveCooldown = 30

#
#   LLMChatter.GroupChatter.SpellCastChance
#       Percent chance (0-100) that a buff/heal/CC
#       spell cast triggers a group reaction.
#       Resurrect spells always trigger (100%).
#       Default: 15
#
LLMChatter.GroupChatter.SpellCastChance = 15

#
#   LLMChatter.GroupChatter.KillCooldown
#       Per-group cooldown (seconds) between kill
#       reactions for normal mobs. Boss/rare kills
#       bypass this cooldown. Also used as the base
#       for combat enter cooldown (elite = half).
#       Default: 120
#
LLMChatter.GroupChatter.KillCooldown = 120

#
#   LLMChatter.GroupChatter.DeathCooldown
#       Per-group cooldown (seconds) between death
#       reactions. Kept short since wipes cause
#       rapid sequential deaths.
#       Default: 30
#
LLMChatter.GroupChatter.DeathCooldown = 30

#
#   LLMChatter.GroupChatter.LootCooldown
#       Per-group cooldown (seconds) between loot
#       reactions for green/blue items.
#       Epic+ loot bypasses this cooldown.
#       Default: 60
#
LLMChatter.GroupChatter.LootCooldown = 60

#
#   LLMChatter.GroupChatter.PlayerMsgCooldown
#       Per-group cooldown (seconds) between bot reactions
#       to player chat messages in party chat. When a real
#       player types in party, a bot may respond. This
#       cooldown prevents bots from replying to every message.
#       Default: 15
#
LLMChatter.GroupChatter.PlayerMsgCooldown = 15

#
#   LLMChatter.GroupChatter.ResurrectChance
#       Percent chance (0-100) that being resurrected
#       triggers a group reaction. Resurrections are
#       rare so 100% is recommended.
#       Default: 100
#
LLMChatter.GroupChatter.ResurrectChance = 100

#
#   LLMChatter.GroupChatter.ResurrectCooldown
#       Per-group cooldown (seconds) between resurrect
#       reactions.
#       Default: 30
#
LLMChatter.GroupChatter.ResurrectCooldown = 30

#
#   LLMChatter.GroupChatter.ZoneTransitionChance
#       Percent chance (0-100) that entering a new zone
#       triggers a group reaction. Cooldown prevents
#       spam when traveling through multiple zones.
#       Default: 100
#
LLMChatter.GroupChatter.ZoneTransitionChance = 100

#
#   LLMChatter.GroupChatter.ZoneTransitionCooldown
#       Per-group cooldown (seconds) between zone
#       transition reactions. Zone changes can cluster
#       when traveling through multiple zones.
#       Default: 120
#
LLMChatter.GroupChatter.ZoneTransitionCooldown = 120

#
#   LLMChatter.GroupChatter.DungeonEntryChance
#       Percent chance (0-100) that entering a dungeon
#       or raid triggers a group reaction.
#       Default: 100
#
LLMChatter.GroupChatter.DungeonEntryChance = 100

#
#   LLMChatter.GroupChatter.DungeonEntryCooldown
#       Per-group cooldown (seconds) between dungeon
#       entry reactions. One reaction per dungeon run.
#       Default: 300
#
LLMChatter.GroupChatter.DungeonEntryCooldown = 300

#
#   LLMChatter.GroupChatter.WipeChance
#       Percent chance (0-100) that a group wipe
#       triggers a reaction. Wipes are dramatic and
#       rare so 100% is recommended.
#       Default: 100
#
LLMChatter.GroupChatter.WipeChance = 100

#
#   LLMChatter.GroupChatter.WipeCooldown
#       Per-group cooldown (seconds) between group wipe
#       reactions. Prevents double-fire during corpse
#       runs.
#       Default: 120
#
LLMChatter.GroupChatter.WipeCooldown = 120

#
#   LLMChatter.GroupChatter.CorpseRunChance
#       Chance (0-100) for corpse run commentary
#       when a bot releases spirit and becomes a
#       ghost. Fires on OnPlayerRepop.
#       Default: 80
#
LLMChatter.GroupChatter.CorpseRunChance = 80

#
#   LLMChatter.GroupChatter.CorpseRunCooldown
#       Seconds between corpse run events per
#       group. Prevents spam if multiple bots die
#       in quick succession.
#       Default: 120
#
LLMChatter.GroupChatter.CorpseRunCooldown = 120

#
#    LLMChatter.GroupChatter.FarewellEnable
#        Enable farewell messages when bots leave the group
#        Default: 1
#
LLMChatter.GroupChatter.FarewellEnable = 1

#
#    LLMChatter.GroupChatter.CompositionCommentChance
#        Percent chance (0-100) that a bot comments on
#        the group composition after joining. Requires
#        2+ bots in the group. Keep low to avoid chat
#        flood when inviting multiple bots quickly.
#        Default: 10
#
LLMChatter.GroupChatter.CompositionCommentChance = 10

#
#    LLMChatter.GroupChatter.StateCalloutEnable
#        Enable proactive state-triggered callouts
#        (low health, OOM, aggro loss)
#        Default: 1
#
#    LLMChatter.GroupChatter.StateCalloutLowHealth
#        Enable low health callouts
#        Default: 1
#
#    LLMChatter.GroupChatter.StateCalloutOom
#        Enable out-of-mana callouts
#        Default: 1
#
#    LLMChatter.GroupChatter.StateCalloutAggro
#        Enable aggro loss callouts (tanks only)
#        Default: 1
#
#    LLMChatter.GroupChatter.StateCalloutChance
#        Percent chance to fire a callout when
#        condition is met (0-100)
#        Default: 60
#
#    LLMChatter.GroupChatter.StateCalloutCooldown
#        Cooldown per bot per callout type in
#        seconds
#        Default: 30
#

###############################################################################
# PRE-CACHED INSTANT REACTIONS
#
#   Pre-generates LLM responses in the background and delivers them instantly
#   from C++ when combat hooks fire, avoiding 3-8s LLM latency.
#   Cache misses fall back to the normal live LLM path.
###############################################################################

#
#   LLMChatter.GroupChatter.PreCacheEnable
#       Master toggle for pre-cached instant reactions.
#       When enabled, combat-time reactions are served
#       from a pre-generated cache for instant delivery.
#       Default: 1 (enabled)
#
LLMChatter.GroupChatter.PreCacheEnable = 1

#
#   LLMChatter.GroupChatter.PreCacheCombatEnable
#       Pre-cache pull cries (combat_pull category).
#       Default: 1
#
LLMChatter.GroupChatter.PreCacheCombatEnable = 1

#
#   LLMChatter.GroupChatter.PreCacheStateEnable
#       Pre-cache state callouts (low_health, oom,
#       aggro_loss categories).
#       Default: 1
#
LLMChatter.GroupChatter.PreCacheStateEnable = 1

#
#   LLMChatter.GroupChatter.PreCacheSpellEnable
#       Pre-cache spell support reactions
#       (spell_support category).
#       Default: 1
#
LLMChatter.GroupChatter.PreCacheSpellEnable = 1

#
#   LLMChatter.GroupChatter.PreCacheDepthCombat
#       Number of ready cached responses to maintain
#       per bot for combat_pull category.
#       Default: 2
#
LLMChatter.GroupChatter.PreCacheDepthCombat = 2

#
#   LLMChatter.GroupChatter.PreCacheDepthState
#       Number of ready cached responses to maintain
#       per bot per state category (low_health, oom,
#       aggro_loss).
#       Default: 2
#
LLMChatter.GroupChatter.PreCacheDepthState = 2

#
#   LLMChatter.GroupChatter.PreCacheDepthSpell
#       Number of ready cached responses to maintain
#       per bot for spell_support category.
#       Default: 2
#
LLMChatter.GroupChatter.PreCacheDepthSpell = 2

#
#   LLMChatter.GroupChatter.PreCacheTTLSeconds
#       How long (seconds) cached responses remain
#       valid before expiring. Expired rows are
#       cleaned up by the bridge.
#       Default: 3600 (1 hour)
#
LLMChatter.GroupChatter.PreCacheTTLSeconds = 3600

#
#   LLMChatter.GroupChatter.PreCacheGeneratePerLoop
#       Max number of new cached responses to generate
#       per bridge loop iteration. Keeps refill from
#       blocking normal event processing.
#       Default: 2
#
LLMChatter.GroupChatter.PreCacheGeneratePerLoop = 2

#
#   LLMChatter.GroupChatter.PreCacheFallbackToLive
#       When cache is empty (miss), fall back to the
#       normal live LLM path (3-8s latency).
#       Set to 0 to skip entirely on miss (testing).
#       Default: 1
#
LLMChatter.GroupChatter.PreCacheFallbackToLive = 1

LLMChatter.GroupChatter.StateCalloutEnable = 1
LLMChatter.GroupChatter.StateCalloutLowHealth = 1
LLMChatter.GroupChatter.StateCalloutOom = 1
LLMChatter.GroupChatter.StateCalloutAggro = 1
LLMChatter.GroupChatter.StateCalloutChance = 60
LLMChatter.GroupChatter.StateCalloutCooldown = 30

###############################################################################
# RP ENRICHMENT SETTINGS
###############################################################################

#
#   LLMChatter.RaceLoreChance
#       Percent chance (0-100) that race-specific lore and worldview
#       flavor text is injected into chatter prompts (roleplay mode only).
#       Higher = more frequent lore references in bot speech.
#       Default: 15
#
LLMChatter.RaceLoreChance = 20

#
#   LLMChatter.RaceVocabChance
#       Percent chance (0-100) that race-specific vocabulary words
#       (greetings, exclamations, farewells) are injected into bot
#       speech. Applies in both normal and roleplay modes.
#       Higher = more frequent racial flavor words.
#       Default: 15
#
LLMChatter.RaceVocabChance = 20

###############################################################################
# GENERAL CHANNEL REACTIONS
#
#   When a real player types in the General channel, nearby bots may react
#   with a statement or short conversation. Zone-scoped with cooldowns.
#
###############################################################################

#
#   LLMChatter.GeneralChat.Enable
#       Enable bot reactions to player messages in General channel
#       Default: 1
#
LLMChatter.GeneralChat.Enable = 1

#
#   LLMChatter.GeneralChat.ReactionChance
#       Chance (0-100) a bot reacts to a non-question message
#       Default: 40
#
LLMChatter.GeneralChat.ReactionChance = 40

#
#   LLMChatter.GeneralChat.QuestionChance
#       Chance (0-100) a bot reacts to a question (ends with ?)
#       Default: 80
#
LLMChatter.GeneralChat.QuestionChance = 80

#
#   LLMChatter.GeneralChat.Cooldown
#       Per-zone cooldown in seconds between reactions
#       Default: 30
#
LLMChatter.GeneralChat.Cooldown = 30

#
#   LLMChatter.GeneralChat.ConversationChance
#       Chance (0-100) reaction becomes a multi-bot conversation
#       vs single statement
#       Default: 30
#
LLMChatter.GeneralChat.ConversationChance = 30

###############################################################################
#
#   QUICK ANALYZE (UTILITY LLM CALLS)
#
#   Configure the provider and model for fast, cheap LLM utility calls used
#   for pre-processing tasks like determining which bot a player is addressing,
#   intent classification, and context analysis. These calls need to be fast
#   and cheap — pick your smallest/fastest model.
#
#   If left empty, defaults to the main provider with the fastest available
#   model (Haiku for Anthropic, gpt-4o-mini for OpenAI, main model for Ollama).
#
###############################################################################

#
#   LLMChatter.QuickAnalyze.Provider
#       Provider for utility LLM calls: anthropic, openai, or ollama
#       Leave empty to use the main LLMChatter.Provider
#       Default: "" (use main provider)
#
LLMChatter.QuickAnalyze.Provider =

#
#   LLMChatter.QuickAnalyze.Model
#       Model for utility LLM calls (e.g. claude-haiku-4-5-20251001,
#       gpt-4o-mini, qwen3:4b). Leave empty to auto-select the fastest
#       model for the provider.
#       Default: "" (auto-select)
#
LLMChatter.QuickAnalyze.Model =
